{
  "name": "toneai-setup",
  "version": "1.0.0",
  "description": "Setup wizard for ToneAI",
  "author": "steve-krisjanovs",
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile toneai-setup",
    "build:win": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile toneai-setup-win-x64.exe",
    "build:mac-arm": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile toneai-setup-mac-arm64",
    "build:mac-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile toneai-setup-mac-x64",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile toneai-setup-linux-x64"
  }
}
